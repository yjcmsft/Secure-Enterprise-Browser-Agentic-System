NODE_ENV=development
PORT=3000

# Azure Identity (Entra ID)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure AI Foundry Agent Service
AZURE_AI_PROJECT_ENDPOINT=

# Azure OpenAI (used by task planner for workflow decomposition)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_MODEL=gpt-4o

CONTENT_SAFETY_ENDPOINT=
CONTENT_SAFETY_KEY=
CONTENT_SAFETY_BLOCK_THRESHOLD=4

COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=browser-agent-db
COSMOS_AUDIT_CONTAINER=audit-logs
COSMOS_WORKFLOW_CONTAINER=workflow-state
COSMOS_MEMORY_CONTAINER=conversation-memory

KEY_VAULT_URL=

ALLOWED_URL_PATTERNS=https://*.microsoft.com/*,https://*.office.com/*,https://sec.gov/*
APPROVAL_TIMEOUT_MS=300000
MAX_BROWSER_CONCURRENCY=10
SESSION_TTL_MS=1800000

GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_DEFAULT_SCOPE=https://graph.microsoft.com/.default
TARGET_APP_SCOPE=api://browser-agent/.default

# AG-UI streaming (set to false to disable the SSE streaming endpoint)
AGUI_ENABLED=true

AZURE_ENV_NAME=
AZURE_LOCATION=eastus
