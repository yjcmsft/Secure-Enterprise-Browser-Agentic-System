# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure Entra ID
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DATABASE=browser-agent-db

# Azure Key Vault
KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# Azure AI Content Safety
CONTENT_SAFETY_ENDPOINT=https://your-content-safety.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=your-content-safety-key

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key

# Server
PORT=3000
NODE_ENV=development

# URL Allowlist (comma-separated domains)
URL_ALLOWLIST=servicenow.corp,jira.corp,grafana.corp,workday.corp,microsoft.com,abc.xyz,ir.aboutamazon.com

# Browser Pool
BROWSER_POOL_MAX_SIZE=10
BROWSER_POOL_TIMEOUT_MS=30000
