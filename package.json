{
  "name": "secure-enterprise-browser-agent",
  "version": "1.0.0",
  "description": "An Azure AI Foundry agent that securely navigates, reads, and acts across enterprise web applications with AG-UI streaming",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "deploy:preview": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-preview.ps1",
    "deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy.ps1"
  },
  "keywords": [
    "azure-ai-foundry",
    "agent-framework",
    "ag-ui",
    "copilotkit",
    "browser-automation",
    "enterprise",
    "azure"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.42",
    "@ag-ui/encoder": "^0.0.43",
    "@azure-rest/ai-content-safety": "^1.0.0",
    "@azure/ai-projects": "^1.0.0-beta.10",
    "@azure/cosmos": "^4.2.0",
    "@azure/identity": "^4.5.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "@copilotkit/runtime": "^1.9.3",
    "@github/copilot-sdk": "^0.1.30",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "axios": "^1.7.9",
    "express": "^4.21.1",
    "express-rate-limit": "^8.2.1",
    "isomorphic-fetch": "^3.0.0",
    "playwright": "^1.49.1",
    "swagger-parser": "^10.0.3",
    "winston": "^3.17.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yjcmsft/Secure-Enterprise-Browser-Agentic-System.git"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/yjcmsft/Secure-Enterprise-Browser-Agentic-System/issues"
  },
  "homepage": "https://github.com/yjcmsft/Secure-Enterprise-Browser-Agentic-System#readme"
}
